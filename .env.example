# ShineMonitor Socket Platform
SOCKET_API_BASE_URL=https://api.litexmonitor.com
SOCKET_API_USER=aitos
SOCKET_API_PASSWORD=a123456
DEFAULT_DEVICE_PN=your-device-pn-here
DEFAULT_DEVICE_SN=your-device-sn-here
